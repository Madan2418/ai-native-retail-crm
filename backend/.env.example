# CRM Backend Environment Variables
# Copy this to .env and fill in your values

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# Redis (Upstash)
REDIS_URL=rediss://:[password]@[host].upstash.io:6380

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# Channel Service URL
CHANNEL_SERVICE_URL=http://localhost:4000

# This service's receipts endpoint (for Channel Service to call back)
CRM_RECEIPTS_URL=http://localhost:3000/api/receipts

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3001

# Environment
NODE_ENV=development
PORT=3000
